# Copy to .env and set a long random secret before deploying.
# All admin APIs (setup UI actions, config save, uploads) require this value.
ADMIN_KEY=

# Used to sign the guest "site gate" cookie. Set a long random value in production.
SECRET_KEY=

# Optional: document the admin UI path slug (must match REACT_APP_ADMIN_SETUP_PATH in frontend/.env at build time).
# Example: if frontend has REACT_APP_ADMIN_SETUP_PATH=my-party-2025, share only:
#   https://your-domain/setup/my-party-2025
# ADMIN_SETUP_PATH=my-party-2025
